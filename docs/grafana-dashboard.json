{
  "title": "Code Intelligence Platform",
  "uid": "code-intel-dashboard",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "HTTP Requests / sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[1m])) by (status_code)",
          "legendFormat": "{{status_code}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "HTTP p95 Latency (seconds)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, route))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Graph Size (Nodes)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(pipeline_nodes_total)",
          "legendFormat": "Nodes"
        }
      ]
    },
    {
      "id": 4,
      "title": "Graph Size (Edges)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "targets": [
        {
          "expr": "sum(pipeline_edges_total)",
          "legendFormat": "Edges"
        }
      ]
    },
    {
      "id": 5,
      "title": "Active Sessions",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "active_sessions_total",
          "legendFormat": "Sessions"
        }
      ]
    },
    {
      "id": 6,
      "title": "Heap Usage (MB)",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 1000 },
              { "color": "red", "value": 2000 }
            ]
          },
          "max": 4096
        }
      },
      "targets": [
        {
          "expr": "process_heap_bytes / 1024 / 1024",
          "legendFormat": "Heap MB"
        }
      ]
    },
    {
      "id": 7,
      "title": "Auth Attempts",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "sum(rate(auth_attempts_total[5m])) by (outcome)",
          "legendFormat": "{{outcome}}"
        }
      ]
    },
    {
      "id": 8,
      "title": "MCP Tool Calls / sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "sum(rate(mcp_tool_calls_total[1m])) by (tool)",
          "legendFormat": "{{tool}}"
        }
      ]
    },
    {
      "id": 9,
      "title": "Pipeline Analyses",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "sum(pipeline_analyses_total) by (status)",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 10,
      "title": "Rate Limit Hits / sec",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 16, "x": 8, "y": 20 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status_code=\"429\"}[1m]))",
          "legendFormat": "429 / sec"
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "repo",
        "type": "query",
        "query": "label_values(pipeline_nodes_total, repo)",
        "label": "Repository"
      }
    ]
  }
}
