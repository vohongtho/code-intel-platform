# ──────────────────────────────────────────────────────────────────────────────
# code-intel-platform — environment variable reference
#
# Copy this file to .env and fill in the values for your deployment.
# Lines beginning with # are comments and are ignored.
#
# ⚠  Never commit your actual .env file to version control.
# ──────────────────────────────────────────────────────────────────────────────


# ── Runtime ───────────────────────────────────────────────────────────────────

# Node.js environment. Use "production" for all networked deployments.
# Affects: secure cookies, CSP headers, OIDC, logging verbosity.
NODE_ENV=production

# Log level: error | warn | info | debug  (default: info)
LOG_LEVEL=info


# ── Server ────────────────────────────────────────────────────────────────────

# Base URL shown in OAuth redirects and generated links.
# Must match the public URL of your deployment (no trailing slash).
CODE_INTEL_BASE_URL=http://localhost:4747

# Comma-separated list of allowed CORS origins (no wildcard in production).
# Example: https://mycompany.com,https://ci.mycompany.com
CODE_INTEL_CORS_ORIGINS=http://localhost:4747


# ── Authentication — Sessions ─────────────────────────────────────────────────

# Session cookie TTL in hours (default: 8).
CODE_INTEL_SESSION_TTL_HOURS=8

# Secret used to sign CSRF double-submit cookies.
# Generate: openssl rand -hex 32
CODE_INTEL_CSRF_SECRET=change-me-to-a-random-hex-string


# ── Authentication — API Tokens ───────────────────────────────────────────────

# Bearer token for MCP server / CLI non-interactive access.
# Create with: code-intel token create --name "my-token"
CODE_INTEL_TOKEN=


# ── Authentication — OIDC / OAuth2 (optional) ─────────────────────────────────

# URL of the OIDC issuer (discovery endpoint: <issuer>/.well-known/openid-configuration).
# Supported: GitHub, GitLab, Google, Okta, Azure AD, or any OIDC-compliant provider.
# Leave blank to disable OIDC and use local accounts only.
CODE_INTEL_OIDC_ISSUER=

# OAuth2 client ID and secret registered with the provider.
CODE_INTEL_OIDC_CLIENT_ID=
CODE_INTEL_OIDC_CLIENT_SECRET=

# Redirect URI — must be registered with the provider.
# Usually: <CODE_INTEL_BASE_URL>/auth/callback
CODE_INTEL_OIDC_REDIRECT_URI=http://localhost:4747/auth/callback

# Space-separated OIDC scopes (default: openid profile email).
CODE_INTEL_OIDC_SCOPES=openid profile email

# Role assigned to newly provisioned OIDC users.
# One of: admin | analyst | viewer | repo-owner  (default: viewer)
CODE_INTEL_OIDC_DEFAULT_ROLE=viewer


# ── Secrets & Encryption ──────────────────────────────────────────────────────

# Path to the encrypted .secrets store (default: ~/.code-intel/.secrets).
CODE_INTEL_SECRETS_PATH=

# AES-256-GCM master key for the .secrets store — 64 hex characters (256 bits).
# Generate: openssl rand -hex 32
# ⚠  Store in a secrets manager (Vault, AWS SSM) — never commit this value.
CODE_INTEL_SECRET_KEY=

# Disable OS keychain (keytar) and always use the encrypted-file backend.
# Set to "true" in headless/server environments where keytar is unavailable.
CODE_INTEL_DISABLE_KEYTAR=false

# scrypt CPU/memory cost parameter N (default: 16384, lower only for tests).
# Must be a power of 2. Increase for higher security; decrease for faster tests.
# CODE_INTEL_SCRYPT_N=16384


# ── Storage ───────────────────────────────────────────────────────────────────

# Absolute path to the users/tokens/sessions SQLite database.
# Default: ~/.code-intel/users.db
CODE_INTEL_USERS_DB_PATH=


# ── Backup ────────────────────────────────────────────────────────────────────

# AES-256-GCM encryption key for backup archives — 64 hex characters (256 bits).
# Generate: openssl rand -hex 32
# ⚠  Store safely — without this key, backups cannot be decrypted.
CODE_INTEL_BACKUP_KEY=

# Enable automatic scheduled backups (default: false).
CODE_INTEL_BACKUP_SCHEDULE_ENABLED=false

# Hour (0–23, UTC) at which the daily backup runs (default: 2).
CODE_INTEL_BACKUP_SCHEDULE_HOUR=2

# Comma-separated list of repo paths to back up on schedule.
# If empty, all registered repos are backed up.
CODE_INTEL_BACKUP_SCHEDULE_REPOS=

# ── Backup — S3 (optional) ────────────────────────────────────────────────────

# S3 bucket name for offsite backup storage.
CODE_INTEL_BACKUP_S3_BUCKET=

# AWS region of the S3 bucket (e.g. us-east-1).
CODE_INTEL_BACKUP_S3_REGION=us-east-1

# AWS credentials with PutObject / GetObject / ListObjectsV2 on the bucket.
CODE_INTEL_BACKUP_S3_ACCESS_KEY_ID=
CODE_INTEL_BACKUP_S3_SECRET_ACCESS_KEY=

# Key prefix / folder inside the bucket (default: code-intel-backups/).
CODE_INTEL_BACKUP_S3_PREFIX=code-intel-backups/

# Automatically upload new backups to S3 after creation (default: false).
CODE_INTEL_BACKUP_S3_AUTO_UPLOAD=false


# ── Observability — OpenTelemetry (optional) ──────────────────────────────────

# Enable distributed tracing (default: false — opt-in).
CODE_INTEL_OTEL_ENABLED=false

# OTLP/HTTP collector endpoint (default: http://localhost:4318).
CODE_INTEL_OTEL_ENDPOINT=http://localhost:4318

# Service name reported in traces (default: code-intel).
CODE_INTEL_OTEL_SERVICE=code-intel

# Deployment environment tag (default: NODE_ENV value).
CODE_INTEL_OTEL_ENV=production


# ── Rate Limiting ─────────────────────────────────────────────────────────────

# Maximum requests per IP per window (default: 100).
CODE_INTEL_RATE_LIMIT_MAX=100

# Rate limit window in milliseconds (default: 900000 = 15 min).
CODE_INTEL_RATE_LIMIT_WINDOW_MS=900000


# ── AI Governance (optional) ──────────────────────────────────────────────────

# Enable opt-in audit logging of all LLM/embedding invocations (default: false).
# Logs model, userId, purpose, token counts — never raw source code.
CODE_INTEL_GOVERNANCE_LOGGING=false

# Path to the JSONL governance log file.
# Default: ~/.code-intel/llm-governance.jsonl
CODE_INTEL_GOVERNANCE_LOG_PATH=


# ── Development only ─────────────────────────────────────────────────────────

# Auto-login as the single admin user when running on localhost.
# ⚠  NEVER enable in production — for local development only.
CODE_INTEL_DEV_AUTO_LOGIN=false
