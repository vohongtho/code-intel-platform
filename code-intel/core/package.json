{
  "name": "@vohongtho.infotech/code-intel",
  "version": "1.0.0",
  "description": "Static code analysis platform — builds a Knowledge Graph from source code with Web UI, HTTP API, CLI, and MCP server",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "code-intel": "dist/cli/main.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "code-intelligence",
    "knowledge-graph",
    "static-analysis",
    "ast",
    "graph",
    "mcp",
    "vector-search",
    "code-search",
    "cli"
  ],
  "homepage": "https://github.com/vohongtho/code-intel-platform",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vohongtho/code-intel-platform.git"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts && node scripts/add-shebang.mjs && node scripts/copy-grammars.mjs",
    "typecheck": "tsc -b --noEmit",
    "prepublishOnly": "npm run build",
    "clean": "rm -rf dist dist-tests *.tsbuildinfo",
    "test": "tsc -b tsconfig.test.json && NODE_ENV=test node --test --test-concurrency=1 dist-tests/tests/**/*.test.js",
    "test:coverage": "tsc -b tsconfig.test.json && NODE_ENV=test npx c8 --all --include='dist-tests/src/**/*.js' --exclude='dist-tests/src/cli/main.js' --exclude='dist-tests/src/mcp-server/**' --reporter=text --reporter=lcov --reporter=json-summary node --test --test-concurrency=1 dist-tests/tests/**/*.test.js"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@ladybugdb/core": "^0.15.4",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.73.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-node": "^0.215.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@types/compression": "^1.8.1",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.9.0",
    "anymatch": "^3.1.3",
    "braces": "^3.0.2",
    "chokidar": "^3.6.0",
    "glob-parent": "^5.1.2",
    "is-binary-path": "^2.1.0",
    "is-glob": "^4.0.1",
    "normalize-path": "^3.0.0",
    "readdirp": "^3.6.0",
    "code-intel-shared": "^0.1.0",
    "commander": "^14.0.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csrf-csrf": "^4.0.3",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "graphology": "^0.26.0",
    "graphology-communities-louvain": "^2.0.1",
    "helmet": "^8.1.0",
    "openid-client": "^6.8.4",
    "prom-client": "^15.1.3",
    "tree-sitter-c": "0.23.2",
    "tree-sitter-c-sharp": "0.23.1",
    "tree-sitter-cpp": "^0.23.4",
    "tree-sitter-go": "^0.23.4",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-javascript": "^0.23.1",
    "tree-sitter-php": "^0.23.12",
    "tree-sitter-python": "^0.23.6",
    "tree-sitter-ruby": "^0.23.1",
    "tree-sitter-rust": "0.23.1",
    "tree-sitter-typescript": "^0.23.2",
    "uuid": "^14.0.0",
    "web-tree-sitter": "^0.26.8",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "c8": "^11.0.0",
    "esbuild": "^0.28.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "optionalDependencies": {
    "keytar": "^7.9.0",
    "tree-sitter-dart": "^1.0.0",
    "tree-sitter-kotlin": "^0.3.8",
    "tree-sitter-swift": "^0.7.1"
  },
  "overrides": {
    "onnxruntime-node": "^1.25.1",
    "node-domexception": "^2.0.2"
  }
}
