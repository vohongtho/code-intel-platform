{
  "name": "@vohongtho.infotech/code-intel",
  "version": "0.1.3",
  "description": "Static code analysis platform — builds a Knowledge Graph from source code with Web UI, HTTP API, CLI, and MCP server",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "code-intel": "./dist/cli/main.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "code-intelligence",
    "knowledge-graph",
    "static-analysis",
    "ast",
    "graph",
    "mcp",
    "vector-search",
    "code-search",
    "cli"
  ],
  "homepage": "https://github.com/vohongtho/code-intel-platform",
  "repository": {
    "type": "git",
    "url": "https://github.com/vohongtho/code-intel-platform"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc -b",
    "prepublishOnly": "npm run build",
    "clean": "rm -rf dist dist-tests *.tsbuildinfo",
    "test": "tsc -b tsconfig.test.json && node --test dist-tests/tests/**/*.test.js"
  },
  "dependencies": {
    "code-intel-shared": "^0.1.0",
    "@ladybugdb/core": "^0.15.3",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@xenova/transformers": "^2.17.2",
    "commander": "^12.0.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "graphology": "^0.25.4",
    "graphology-communities-louvain": "^2.0.1",
    "web-tree-sitter": "^0.24.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  }
}
